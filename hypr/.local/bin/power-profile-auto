#!/bin/bash
# Auto-switch power profile on AC power change
# Triggered by udev rule on plug/unplug

sleep 1  # let firmware settle after AC state change

# Detect AC adapter
ac_online=0
if [ -f /sys/class/power_supply/AC/online ]; then
    ac_online=$(cat /sys/class/power_supply/AC/online)
elif [ -f /sys/class/power_supply/ACAD/online ]; then
    ac_online=$(cat /sys/class/power_supply/ACAD/online)
else
    for adapter in /sys/class/power_supply/*/online; do
        if [ -f "$adapter" ]; then
            ac_online=$(cat "$adapter")
            break
        fi
    done
fi

# Set profile based on AC state
if [ "$ac_online" = "1" ]; then
    powerprofilesctl set balanced
    profile=balanced
else
    powerprofilesctl set power-saver
    profile=power-saver
fi

# vivo (AMD) applies per-profile TDP + the 2GHz amd_pstate freq-cap fix via an
# optional hook (power-profile-tdp-hook, installed by the vivo/ stow package).
# Intel machines don't install it, so this is a clean no-op there. Runs as root
# from udev; the hook drops privileges handling internally.
if [ -x /home/netanel/.local/bin/power-profile-tdp-hook ]; then
    [ "$ac_online" = "1" ] && sleep 3  # let firmware settle before the pstate fix
    /home/netanel/.local/bin/power-profile-tdp-hook "$profile"
fi