#!/bin/bash
# Auto-switch power profile + TDP on AC power change
# Triggered by udev rule on plug/unplug

sleep 1  # let firmware settle after AC state change

# Detect AC adapter
ac_online=0
if [ -f /sys/class/power_supply/AC/online ]; then
    ac_online=$(cat /sys/class/power_supply/AC/online)
elif [ -f /sys/class/power_supply/ACAD/online ]; then
    ac_online=$(cat /sys/class/power_supply/ACAD/online)
else
    for adapter in /sys/class/power_supply/*/online; do
        if [ -f "$adapter" ]; then
            ac_online=$(cat "$adapter")
            break
        fi
    done
fi

# Set profile + TDP first
if [ "$ac_online" = "1" ]; then
    powerprofilesctl set balanced
    ryzenadj --stapm-limit=25000 --fast-limit=30000 --slow-limit=25000 --tctl-temp=90 2>/dev/null
else
    powerprofilesctl set power-saver
    ryzenadj --stapm-limit=15000 --fast-limit=20000 --slow-limit=15000 --tctl-temp=75 2>/dev/null
fi

# Fix 2GHz frequency cap (firmware bug on AC state change)
# Toggle amd_pstate driver to force reinitialize — more reliable than writing max freq
sleep 3
pstate="/sys/devices/system/cpu/amd_pstate/status"
echo "passive" > "$pstate" 2>/dev/null
sleep 0.1
echo "active" > "$pstate" 2>/dev/null
