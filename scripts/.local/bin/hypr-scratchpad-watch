#!/bin/bash
# Watch Hyprland events and update scratchpad count in real-time

# Find Hyprland socket
if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
    SOCKET="/run/user/$(id -u)/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
else
    SOCKET=$(find /run/user/$(id -u)/hypr -name ".socket2.sock" -type s 2>/dev/null | head -1)
fi

if [ -z "$SOCKET" ] || [ ! -S "$SOCKET" ]; then
    echo '{"text": "", "class": "", "tooltip": "Hyprland socket not found"}'
    exit 1
fi

# Kill child event source when we exit (so waybar restart doesn't leak orphans)
cleanup() {
    [[ -n "${SOCAT_PID:-}" ]] && kill "$SOCAT_PID" 2>/dev/null
    exit 0
}
trap cleanup EXIT INT TERM PIPE

# Emit current count and visibility. Exits the script if waybar closed the pipe.
get_status() {
    local count is_visible
    count=$(hyprctl clients -j 2>/dev/null | jq '[.[] | select(.workspace.name == "special:magic")] | length' 2>/dev/null)
    is_visible=$(hyprctl monitors -j 2>/dev/null | jq -r '[.[] | select(.specialWorkspace.name == "special:magic")] | length > 0' 2>/dev/null)
    [[ "$count" =~ ^[0-9]+$ ]] || count=0

    if [ "$count" -eq 0 ]; then
        echo '{"text": "", "class": ""}' || exit 0
    elif [ "$is_visible" == "true" ]; then
        echo "{\"text\": \"󰝖 $count\", \"class\": \"active\"}" || exit 0
    else
        echo "{\"text\": \"󰝖 $count\", \"class\": \"\"}" || exit 0
    fi
}

get_status

# Stream Hyprland events via a background socat so we can kill it on exit
exec 3< <(socat -u "UNIX-CONNECT:$SOCKET" -)
SOCAT_PID=$!

while read -r event <&3; do
    case "$event" in
        workspace*|activespecial*|movewindow*|openwindow*|closewindow*)
            get_status
            ;;
    esac
done
