#!/bin/bash
# Watch and display windows in active workspace with focus indicator

# Find Hyprland socket
if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
    SOCKET="/run/user/$(id -u)/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
else
    SOCKET=$(find /run/user/$(id -u)/hypr -name ".socket2.sock" -type s 2>/dev/null | head -1)
fi

if [ -z "$SOCKET" ] || [ ! -S "$SOCKET" ]; then
    echo '{"text": "", "class": ""}'
    exit 1
fi

# Kill child event source when we exit so waybar restarts don't leak orphans
cleanup() {
    [[ -n "${SOCAT_PID:-}" ]] && kill "$SOCAT_PID" 2>/dev/null
    exit 0
}
trap cleanup EXIT INT TERM PIPE

# Strip chars that break Pango markup parsing (control chars except tab, plus ESC sequences)
# and escape the five Pango-reserved characters. Window titles can contain anything.
pango_escape() {
    local s=$1
    s=$(printf '%s' "$s" | tr -d '\000-\010\013\014\016-\037\177')
    s=${s//&/&amp;}
    s=${s//</&lt;}
    s=${s//>/&gt;}
    s=${s//\"/&quot;}
    s=${s//\'/&apos;}
    printf '%s' "$s"
}

get_windows() {
    local scratchpad_visible ws_name ws_class focused_color unfocused_color focused
    scratchpad_visible=$(hyprctl monitors -j 2>/dev/null | jq -r '[.[] | select(.specialWorkspace.name == "special:magic")] | length > 0' 2>/dev/null)

    if [ "$scratchpad_visible" == "true" ]; then
        ws_name="special:magic"
        ws_class="scratchpad"
        focused_color="#f9e2af"
    else
        ws_name=$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.name' 2>/dev/null)
        ws_class="workspace"
        focused_color="#cba6f7"
    fi
    unfocused_color="#6c7086"

    focused=$(hyprctl activewindow -j 2>/dev/null | jq -r '.address // empty' 2>/dev/null)

    local windows_json
    windows_json=$(hyprctl clients -j 2>/dev/null | jq -c --arg ws "$ws_name" --arg focused "$focused" '
        [.[] | select(.workspace.name == $ws)] |
        sort_by(.pid) |
        map({
            addr: .address,
            title: ((.title // .class) | if length > 25 then .[0:22] + "..." else . end),
            full_title: (.title // .class),
            is_focused: (.address == $focused)
        })
    ' 2>/dev/null)

    if [[ -z "$windows_json" || "$windows_json" == "null" ]]; then
        echo '{"text": "", "class": "", "tooltip": ""}' || exit 0
        return
    fi

    local windows="" tooltip_lines=() title full_title is_focused
    while IFS= read -r window; do
        [[ -z "$window" ]] && continue
        title=$(pango_escape "$(jq -r '.title' <<<"$window")")
        full_title=$(pango_escape "$(jq -r '.full_title' <<<"$window")")
        is_focused=$(jq -r '.is_focused' <<<"$window")

        if [ "$is_focused" == "true" ]; then
            windows+="<span foreground='$focused_color' weight='bold'>$title</span>  │  "
            tooltip_lines+=("<span foreground='$focused_color' weight='bold'>▶ $full_title</span>")
        else
            windows+="<span foreground='$unfocused_color'>$title</span>  │  "
            tooltip_lines+=("<span foreground='$unfocused_color'>  $full_title</span>")
        fi
    done < <(jq -c '.[]' <<<"$windows_json")

    windows="${windows%  │  }"

    local tooltip
    tooltip=$(printf '%s\n' "${tooltip_lines[@]}")
    tooltip="${tooltip%$'\n'}"

    if [ -z "$windows" ]; then
        echo '{"text": "", "class": "", "tooltip": ""}' || exit 0
    else
        # jq -Rs reliably JSON-encodes the string (handles newlines, quotes, backslashes)
        local text_escaped tooltip_escaped
        text_escaped=$(printf '%s' "$windows" | jq -Rs .)
        tooltip_escaped=$(printf '%s' "$tooltip" | jq -Rs .)
        echo "{\"text\": ${text_escaped}, \"class\": \"$ws_class\", \"tooltip\": $tooltip_escaped}" || exit 0
    fi
}

get_windows

# Stream Hyprland events via a background socat so we can kill it on exit
exec 3< <(socat -u "UNIX-CONNECT:$SOCKET" -)
SOCAT_PID=$!

while read -r event <&3; do
    case "$event" in
        workspace*|activewindow*|openwindow*|closewindow*|movewindow*|windowtitle*)
            get_windows
            ;;
    esac
done
