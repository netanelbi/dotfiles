#!/bin/bash
# Cycle power profiles: power-saver → balanced → performance
# vivo (AMD) additionally applies per-profile TDP + the 2GHz freq-cap fix via an
# optional hook (power-profile-tdp-hook, vivo/ stow package); Intel skips it.

current=$(powerprofilesctl get)
case "$current" in
    power-saver) new=balanced;    icon="󰗑"; urgency=normal;;
    balanced)    new=performance; icon="󰓅"; urgency=critical;;
    *)           new=power-saver; icon="󰌪"; urgency=low;;
esac

powerprofilesctl set "$new"

notify-send -a power-profile -t 1500 -u "$urgency" \
    -h string:x-canonical-private-synchronous:power \
    "$icon $new"

# Dismiss critical notifications after 2s (swaync ignores timeout for critical)
if [ "$urgency" = "critical" ]; then
    (sleep 2 && swaync-client --close-latest) &
fi

# TDP + freq fix after notification (don't block OSD); vivo-only hook, no-op on Intel
[ -x /home/netanel/.local/bin/power-profile-tdp-hook ] && /home/netanel/.local/bin/power-profile-tdp-hook "$new"

# Clear custom TDP (profile sets default); tdp-watch picks this up via inotify (vivo)
rm -f /tmp/tdp-state