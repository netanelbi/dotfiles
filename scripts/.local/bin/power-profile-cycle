#!/bin/bash
# Cycle power profiles: power-saver → balanced → performance
# Combines powerprofilesctl + ryzenadj TDP limits + frequency cap fix

set_tdp() {
    case "$1" in
        power-saver)
            sudo ryzenadj --stapm-limit=10000 --fast-limit=15000 --slow-limit=10000 --tctl-temp=75 2>/dev/null
            ;;
        balanced)
            sudo ryzenadj --stapm-limit=25000 --fast-limit=30000 --slow-limit=25000 --tctl-temp=90 2>/dev/null
            ;;
        performance)
            sudo ryzenadj --stapm-limit=54000 --fast-limit=65000 --slow-limit=54000 --tctl-temp=100 2>/dev/null
            ;;
    esac
}

fix_freq_cap() {
    sudo /home/netanel/.local/bin/fix-cpu-freq
}

current=$(powerprofilesctl get)
case "$current" in
    power-saver) new=balanced;    icon="󰗑"; urgency=normal;;
    balanced)    new=performance; icon="󰓅"; urgency=critical;;
    *)           new=power-saver; icon="󰌪"; urgency=low;;
esac

powerprofilesctl set "$new"

notify-send -t 1500 -u "$urgency" \
    -h string:x-canonical-private-synchronous:power \
    "$icon $new"

# TDP + freq fix after notification (don't block OSD)
set_tdp "$new"
fix_freq_cap
