#!/usr/bin/env bash
# sunshine-prep
# Runs when a Sunshine stream session starts.
#
# Enables the headless display, sends focus to the streaming workspace,
# and inhibits hypridle so the session doesn't lock during the stream.
#
# Counterpart: sunshine-unprep (runs on stream end)

set -euo pipefail

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/sunshine-prep"
mkdir -p "$STATE_DIR"

# Mark the stream as active so hypr-monitor-handler ignores the panel-disable
# (step 6) and doesn't bounce focus off name:stream. Cleared by sunshine-unprep.
touch "$STATE_DIR/stream-active"

# Hyprland 0.55 stopped auto-importing HYPRLAND_INSTANCE_SIGNATURE into the
# systemd user manager environment, so daemons launched via
# `exec-once = systemctl --user start <svc>` (e.g. sunshine) inherit a
# missing HIS and every `hyprctl` call exits 1 — taking this script down via
# `set -e`. Discover the live instance from $XDG_RUNTIME_DIR/hypr/ as a fallback.
if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
    for dir in "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr/"*/; do
        lock="$dir/hyprland.lock"
        [[ -r "$lock" ]] || continue
        pid=$(head -n1 "$lock" 2>/dev/null || true)
        [[ -n "$pid" && -d "/proc/$pid" ]] || continue
        HYPRLAND_INSTANCE_SIGNATURE=$(basename "$dir")
        export HYPRLAND_INSTANCE_SIGNATURE
        break
    done
fi

# 0. Dismiss hyprlock if it's currently locking the screen — a remote
#    Moonlight client can't type the unlock password, so a stream that
#    starts on a locked session would just show the lock screen.
#    SIGUSR1 is hyprlock's documented graceful unlock signal.
pkill -USR1 hyprlock 2>/dev/null || true

# 1. Enable HEADLESS-2 at 1080p60, parked far offscreen so cursor/windows can't drift onto it
hyprctl keyword monitor "HEADLESS-2,1920x1080@120,4000x0,1"

# 2. Switch to the stream workspace. The static `workspace = name:stream,
#    monitor:HEADLESS-2` binding in hyprland.conf is what pins it to the
#    headless output — earlier versions relied on a `focusmonitor` call here,
#    but Hyprland 0.55 doesn't register the freshly-enabled monitor in time
#    and that call no-ops with "Monitor not found".
hyprctl dispatch workspace name:stream

# 3. Game-window placement is handled by hypr-monitor-handler's openwindow
#    router (gated on the stream-active marker above), NOT by windowrules.
#    When the game window finally maps — even 30s+ into a Wine/Proton/Heroic
#    cold start — the router moves it onto name:stream AND focuses it, by
#    address, so it lands on the captured output and receives remote input.
#    This is class-agnostic and works whether or not the panels are disabled.
#    (The previous `windowrule ... match:class ...` lines used invalid syntax
#    and silently never matched — that was a big part of the unreliability.)

# 4. Inhibit the screensaver so hypridle doesn't lock/dpms during the stream
COOKIE=$(busctl --user --json=short call \
    org.freedesktop.ScreenSaver /org/freedesktop/ScreenSaver \
    org.freedesktop.ScreenSaver Inhibit ss "sunshine" "active stream" \
    | jq -r '.data[0]')
echo "$COOKIE" > "$STATE_DIR/inhibit-cookie"

# 5. Boost to performance profile + TDP for the stream — ONLY when docked (on AC)
#    and not deliberately on power-saver. Mirrors power-profile-cycle's perf preset
#    (54W stapm / 65W fast / 100C) + the freq-cap fix. ryzenadj/fix-cpu-freq run via
#    NOPASSWD sudo. The marker file tells unprep to revert to balanced afterwards.
ac_online=$(cat /sys/class/power_supply/ACAD/online 2>/dev/null || echo 0)
cur_profile=$(powerprofilesctl get 2>/dev/null || echo "")
if [[ "$ac_online" == "1" && -n "$cur_profile" && "$cur_profile" != "power-saver" ]]; then
    powerprofilesctl set performance 2>/dev/null || true
    sudo -n /usr/bin/ryzenadj --stapm-limit=54000 --fast-limit=65000 --slow-limit=54000 --tctl-temp=100 >/dev/null 2>&1 || true
    sudo -n /home/netanel/.local/bin/fix-cpu-freq >/dev/null 2>&1 || true
    touch "$STATE_DIR/profile-boosted"
fi

# 6. Disable the physical panels for the stream's duration — on this APU they only
#    add compositing + memory-bandwidth load (the real bottleneck) and show nothing
#    useful while streaming to a remote client. Done LAST so an earlier failure can't
#    leave the screens off. Re-enabled by sunshine-unprep, and recoverable any time
#    via SUPER+ALT+D (or `hyprctl reload`). Guarded so neither call can abort prep.
hyprctl keyword monitor "eDP-1,disable" || true
hyprctl keyword monitor "DP-2,disable" || true
