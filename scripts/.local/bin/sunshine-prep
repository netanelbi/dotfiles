#!/usr/bin/env bash
# sunshine-prep
# Runs when a Sunshine stream session starts.
#
# Enables the headless display, sends focus to the streaming workspace,
# and inhibits hypridle so the session doesn't lock during the stream.
#
# Counterpart: sunshine-unprep (runs on stream end)

set -euo pipefail

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/sunshine-prep"
mkdir -p "$STATE_DIR"

# 0. Dismiss hyprlock if it's currently locking the screen — a remote
#    Moonlight client can't type the unlock password, so a stream that
#    starts on a locked session would just show the lock screen.
#    SIGUSR1 is hyprlock's documented graceful unlock signal.
pkill -USR1 hyprlock 2>/dev/null || true

# 1. Enable HEADLESS-2 at 1080p60, parked far offscreen so cursor/windows can't drift onto it
hyprctl keyword monitor "HEADLESS-2,1920x1080@60,4000x0,1"

# 2. Move focus to HEADLESS-2 so the next workspace switch creates name:stream there
hyprctl dispatch focusmonitor HEADLESS-2

# 3. Create + focus the stream workspace (lands on HEADLESS-2 since that's focused)
hyprctl dispatch workspace name:stream

# 4. Pin Steam-launched games to name:stream and auto-fullscreen them.
#    Wine/Proton cold start can take 30s+; by the time the game window finally
#    maps, focus has drifted back to eDP-1 and Hyprland places it on whatever
#    workspace is focused *now*, not where prep left it. These rules bypass the
#    focus race entirely. Cleared by `hyprctl reload` in sunshine-unprep.
hyprctl keyword windowrule 'workspace name:stream, match:class ^steam_app'
hyprctl keyword windowrule 'fullscreen on, match:class ^steam_app'

# 5. Inhibit the screensaver so hypridle doesn't lock/dpms during the stream
COOKIE=$(busctl --user --json=short call \
    org.freedesktop.ScreenSaver /org/freedesktop/ScreenSaver \
    org.freedesktop.ScreenSaver Inhibit ss "sunshine" "active stream" \
    | jq -r '.data[0]')
echo "$COOKIE" > "$STATE_DIR/inhibit-cookie"
