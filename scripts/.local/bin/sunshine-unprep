#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/sunshine-prep"
STATE_FILE="$STATE_DIR/monitor.conf"

pkill -CONT hypridle 2>/dev/null || true

if [[ -s "$STATE_FILE" ]]; then
    hyprctl keyword monitor "$(cat "$STATE_FILE")"
    rm -f "$STATE_FILE"
else
    hyprctl keyword monitor "eDP-1,1920x1200@60,1920x0,1.5"
fi
