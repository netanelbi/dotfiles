#!/bin/bash
# Waybar module: show custom TDP when it differs from profile default
# Re-emits whenever /tmp/tdp-state is written or removed
# (the `tdp` CLI writes the file; `power-profile-cycle` removes it)

STATE_FILE=/tmp/tdp-state

# Kill the inotifywait child on exit so waybar restarts don't leak orphans
cleanup() {
    [[ -n "${IW_PID:-}" ]] && kill "$IW_PID" 2>/dev/null
    exit 0
}
trap cleanup EXIT INT TERM PIPE

show_status() {
    local watts
    if [ -f "$STATE_FILE" ]; then
        # Accept only digits; other chars would break JSON
        watts=$(tr -cd '0-9' < "$STATE_FILE" 2>/dev/null)
    fi
    if [ -n "$watts" ]; then
        printf '{"text": "%sW", "tooltip": "Custom TDP: %sW", "class": "active"}\n' "$watts" "$watts" || exit 0
    else
        printf '{"text": "", "class": ""}\n' || exit 0
    fi
}

show_status

# Watch the parent dir filtered by filename: survives unlinking, which a direct
# file watch does not (IN_IGNORED kills the watch silently).
# Background process so $! captures inotifywait's PID for cleanup.
exec 3< <(exec inotifywait -m -q --format '%f' -e close_write -e delete /tmp)
IW_PID=$!
while read -r name <&3; do
    [[ "$name" == "tdp-state" ]] && show_status
done
